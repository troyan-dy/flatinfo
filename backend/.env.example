# Геокодер (OpenStreetMap Nominatim)
GEOCODER_USER_AGENT="flatinfo/0.1 (rent-vs-buy advisor)"

# Минимальный интервал между запросами к геокодеру (сек). Публичный Nominatim
# требует ≤1 req/s. Локально для бодрого автодополнения можно поставить 0.
GEOCODER_MIN_INTERVAL=1.0

# CORS: откуда ходит фронт
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

LOG_LEVEL=INFO
